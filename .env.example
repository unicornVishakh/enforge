# EnzymeForge.ai — environment variables
# Copy this file to .env.local and fill in real values.

# ─── Supabase (https://supabase.com/dashboard) ────────────────────────────────
# Project Settings → API. The anon key is safe to expose in the browser; the
# service-role key is SERVER-ONLY and bypasses RLS — never import it from a
# client component.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── Hugging Face Inference API (https://huggingface.co/settings/tokens) ──────
# A "Read" token is sufficient for the Inference API. Used for ESM-2 protein
# embeddings and masked-LM mutation scoring (facebook/esm2_t6_8M_UR50D).
HUGGINGFACE_API_KEY=

# ─── Optional: BRENDA enzyme database (https://www.brenda-enzymes.org) ────────
# If both vars are set, the BRENDA SOAP API will be queried live. Otherwise the
# app falls back to a curated cached snapshot of common biofuel-relevant
# enzymes (still real Km/kcat values from peer-reviewed literature).
BRENDA_EMAIL=
BRENDA_PASSWORD_HASH=

# ─── Optional: app-level config ───────────────────────────────────────────────
# Public site URL — used in OAuth redirects and for absolute URLs in emails.
# In dev, leave blank to default to http://localhost:3000.
NEXT_PUBLIC_SITE_URL=
